//======================================================
// MINISTRY MODALS
//======================================================

const ministryCards = document.querySelectorAll(".ministry-card");

const ministryModal = document.getElementById("ministryModal");

const modalTitle = document.getElementById("modalTitle");

const modalDescription = document.getElementById("modalDescription");

const modalButton = document.getElementById("modalButton");

const closeModal = document.getElementById("closeModal");


const ministryInfo = {

    worship:{

        title:"Worship & The Word™",

        description:"Join us each week for worship, biblical teaching, prayer, and practical application of God's Word.",

        link:"worship.html"

    },

    faith:{

        title:"Conversations of Faith™",

        description:"Interactive Bible discussions that explore the deeper narrative behind familiar Scriptures.",

        link:"conversations.html"

    },

    prayer:{

        title:"Prayer",

        description:"Share your prayer requests and stand with believers as we seek God's guidance together.",

        link:"prayer.html"

    },

    resources:{

        title:"Resources",

        description:"Bible studies, devotionals, downloadable guides, and tools to strengthen your walk with Christ.",

        link:"resources.html"

    },

    give:{

        title:"Give",

        description:"Partner with Divine Alignment Ministries as we continue sharing the Gospel and serving others.",

        link:"give.html"

    },

    more:{

        title:"Explore More Ministries",

        description:"Additional ministries are prayerfully being prepared and will be introduced in God's timing. Check back soon to discover what is ahead.",

        link:"#"

    }

};


ministryCards.forEach(card=>{

    card.addEventListener("click",()=>{

        const key = card.dataset.ministry;

        modalTitle.textContent = ministryInfo[key].title;

        modalDescription.textContent = ministryInfo[key].description;

        modalButton.href = ministryInfo[key].link;

        ministryModal.style.display="flex";

    });

});


closeModal.addEventListener("click",()=>{

    ministryModal.style.display="none";

});


ministryModal.addEventListener("click",(e)=>{

    if(e.target===ministryModal){

        ministryModal.style.display="none";

    }

});